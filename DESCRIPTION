Package: occJSDM
Type: Package
Title: Fitting occupancy models for eDNA reads data
Version: 0.1.0
Authors@R: c(
    person(
      "Alex", "Diana",
      email = "Alex.diana92@yahoo.it",
      role = c("aut", "cre")
