Package: occJSDM
Type: Package
Title: Simultaneous Fitting of an eDNA-Aware Occupancy and Joint Species Distribution Model
Version: 0.1.0
Authors@R: c(
    person(
      "Alex", "Diana",
      email = "Alex.diana92@yahoo.it",
