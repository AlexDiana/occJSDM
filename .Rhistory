mvrnorm(1, mu[i,], Sigma)
}))
Y = Z > 0
mode(Y) <- "numeric"
lower <- t(sapply(1:n, function(i){
as.vector(ifelse(Y[i,] == 0, -Inf, 0))
}))
upper <- t(sapply(1:n, function(i){
as.vector(ifelse(Y[i,] == 0, 0, Inf))
}))
L <- t(chol(Sigma))
