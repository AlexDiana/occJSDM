gt = 2, # unobserved traits
d = 3, # number of factors
ds = 0, # unobserved spatial factors
sigma_b = .05, # residual coefficient sd
sigma_bs = .01, # residual coefficient sd in space residuals
sigma_ts = .1,
sigma_h = 1, # sd of factor score
sigma_s = .5, # sd of spatial field
l_s = .3, # spatial autocorrelation
tau = rep(0.01, S), # sd of output (only if continuous model is used)
useSpatField = T
)
