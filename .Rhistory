blockSizes <- c(3,5,2,7)
K <- length(blockSizes)
lambda <- runif(K, 0, 1)
Lambda <- matrix(0, sum(blockSizes), K)
Phi <- diag(1, nrow = sum(blockSizes))
for (d in 1:length(blockSizes)) {
Lambda[sum(blockSizes[seq_len(d-1)]) + 1:blockSizes[d],d] <- lambda[d]
diag(Phi[sum(blockSizes[seq_len(d-1)]) + 1:blockSizes[d],
sum(blockSizes[seq_len(d-1)]) + 1:blockSizes[d]]) <- 1 - lambda[d]^2
}
phi <- rcorrmatrix(K)
Sigma <- Lambda %*% phi %*% t(Lambda) + Phi
chol(Sigma)
d <- sum(blockSizes)
n <- 100
