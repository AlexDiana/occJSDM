c_imk <- (y > 0) * (2 - (w_all == 1))
},{
beta_theta <- sample_betatheta_cpp(w, z, beta_theta, idx_z_w, X_theta,
b_betatheta, B_betatheta)
theta <- computeTheta(X_theta, beta_theta)
