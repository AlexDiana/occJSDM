p = matrix(.9, max(P), S),
q = matrix(sample(c(0.05,0.05), size = max(P) * S, replace = T, prob = c(0.95,0.05)),
max(P), S),
theta_baseline = rep(.99, S),
theta0 = rep(0.025, S)
)
}
