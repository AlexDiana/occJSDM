date = as.Date(date, format = "%d/%m/%Y"),
month = as.numeric(format(date, "%m"))) %>%
pivot_longer(cols = starts_with("count"),
names_to = "Replicate",
values_to = "Counts") %>%
pivot_wider(id_cols = c("sample","Replicate","site","Primer",
"year", "season", "visit", "date", "month", "state", "observer","genetic_predator"),
names_from = "consensus_scientific_name",
values_from = "Counts",
values_fn = mean) %>%
mutate(across(starts_with("OTU_"), ~replace_na(., 0))) %>%
dplyr::select(site, year, month, season, visit, date, sample, state,
Primer, Replicate, observer, genetic_predator,
starts_with("OTU")) %>%
rename(Sample = sample,
Site = site) %>%
arrange(Site, year, month, Sample) %>%
mutate(Site = paste(Site, year, month)) %>%
filter(!is.na(genetic_predator),
genetic_predator != "Felis",
genetic_predator != "Lutra",
genetic_predator != "Meles",
genetic_predator != "Canis")
