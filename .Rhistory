p <- matrix(.9, maxL, S)
q <- matrix(.05, maxL, S)
theta0 <- rep(.05, S)
U <- computeU(X_ord, beta_ord, E)
psi <- computePsi(X_psi, beta_psi, U, LL)
}
for (iter in 1:(niter + nburn)) {
